{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/cowork/*",
      "/SCM/*",
      "/favicon.svg",
      "/*.{css,js,svg,png,jpg,jpeg,gif,ico,webp,woff,woff2,ttf,otf}"
    ]
  },
  "routes": [
    { "route": "/cowork", "rewrite": "/cowork/index.html" },
    { "route": "/cowork/dashboard", "rewrite": "/cowork/dashboard.html" },
    { "route": "/SCM", "rewrite": "/index.html" },
    { "route": "/SCM/decision", "rewrite": "/SCM/index.html" },
    { "route": "/SCM/dashboard", "rewrite": "/SCM/dashboard.html" },
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/cowork/*",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "route": "/SCM/*",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".svg": "image/svg+xml",
    ".woff2": "font/woff2"
  }
}
